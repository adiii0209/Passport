# ========================================
# Travel Registration App - Environment
# ========================================

# Server
PORT=5000
NODE_ENV=development

# Google Service Account
# Path to your Google Service Account credentials JSON file
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# Google Drive
# The ID of the root folder where user registration folders will be created
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_drive_folder_id_here

# Google Sheets
# The ID of the Google Sheet for storing registration data
GOOGLE_SHEET_ID=your_sheet_id_here

# OpenRouter API
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
