        .glass-panel {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.4);
        }

        .ocean-shadow {
            box-shadow: 0 20px 40px rgba(0, 51, 102, 0.08);
        }

