                    <div class="space-y-sm">
                        <div class="flex items-center gap-2 text-secondary">
                            <span class="material-symbols-outlined" data-icon="flight_takeoff">flight_takeoff</span>
                            <span class="font-label-sm text-label-sm">TRAVEL</span>
                        </div>
