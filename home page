                data-icon="menu">menu</span>
            <div class="font-headline-md text-headline-md font-bold tracking-tight text-primary">timetours</div>
        </div>
        <div class="flex items-center gap-md">
            <div class="hidden md:flex gap-lg">
                <span
                    class="font-label-sm text-label-sm text-primary cursor-pointer transition-colors hover:bg-secondary-container/30 px-3 py-1 rounded-full">Retreats</span>
                <span
                    class="font-label-sm text-label-sm text-on-surface-variant cursor-pointer transition-colors hover:bg-secondary-container/30 px-3 py-1 rounded-full">Gallery</span>
                <span
                    class="font-label-sm text-label-sm text-on-surface-variant cursor-pointer transition-colors hover:bg-secondary-container/30 px-3 py-1 rounded-full">Support</span>
            </div>
            <div
