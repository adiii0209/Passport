                            <span>ARR: 12:15 PM</span>
                        </div>
                        <div class="relative h-px bg-outline-variant/30 flex items-center justify-center">
                            <span class="material-symbols-outlined text-secondary text-sm absolute"
                                data-icon="flight">flight</span>
                        </div>
                    </div>
                </div>
                <!-- Highlight 4: Concierge -->
                <div
                    class="md:col-span-2 glass-panel ocean-shadow rounded-[24px] p-lg bg-primary-container text-white relative overflow-hidden">
                    <div class="relative z-10 space-y-md md:w-2/3">
                        <h3 class="font-headline-lg text-headline-lg text-tertiary-fixed">Need Assistance?</h3>
                        <p class="font-body-md text-body-md text-blue-100 opacity-90">Our dedicated corporate concierge
