                        <button
                            class="px-6 py-3 bg-tertiary-fixed text-primary font-label-sm text-label-sm rounded-lg hover:bg-tertiary-fixed-dim transition-colors">
                            Contact Concierge
                        </button>
                    </div>
                    <span
                        class="material-symbols-outlined absolute -right-8 -bottom-8 text-[180px] text-white opacity-5 select-none"
                        data-icon="support_agent">support_agent</span>
